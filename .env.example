# คัดลอกไฟล์นี้เป็น .env.local แล้วเติมค่าจริง (ห้าม commit .env.local)
# ค่าเหล่านี้ดึงจาก Supabase Dashboard > Project Settings > API

# URL ของ Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable / anon key — ใช้ฝั่ง client ได้ปลอดภัยเพราะ RLS ป้องกันข้อมูล
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# service_role key (secret) — ใช้ฝั่ง server เท่านั้น สำหรับงาน admin (Phase 6: ลบบัญชีผู้ใช้)
# ⚠️ bypass RLS ทั้งหมด — ห้ามขึ้นต้นด้วย NEXT_PUBLIC_ และห้าม commit ค่าจริงเด็ดขาด
# ดึงจาก Supabase Dashboard > Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# URL หลักของเว็บ (ใช้กับ metadata/sitemap/robots/OG) — Phase 8
# บน Vercel ตั้งเป็นโดเมน production เช่น https://riasec.example.com
# ถ้าไม่ตั้ง จะ fallback เป็น VERCEL_URL (auto) หรือ http://localhost:3000 (dev)
NEXT_PUBLIC_SITE_URL=https://your-domain.example.com

# Cloudflare Turnstile (CAPTCHA ฟรี) — Phase 8, "เปิดใช้ทีหลัง"
# ถ้าไม่ตั้ง → flag ปิด, flow ทำงานเหมือนเดิม (ไม่มี captcha)
# เปิดใช้จริง: (1) สร้าง site/secret key ที่ Cloudflare Turnstile (ฟรี)
#            (2) ใส่ site key ที่นี่  (3) ใส่ secret + เปิด CAPTCHA ใน Supabase Auth (Attack Protection)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
