# คัดลอกไฟล์นี้เป็น .env.local แล้วเติมค่าจริง (ห้าม commit .env.local)
# ค่าเหล่านี้ดึงจาก Supabase Dashboard > Project Settings > API

# URL ของ Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable / anon key — ใช้ฝั่ง client ได้ปลอดภัยเพราะ RLS ป้องกันข้อมูล
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# service_role key (secret) — ใช้ฝั่ง server เท่านั้น สำหรับงาน admin (Phase 6: ลบบัญชีผู้ใช้)
# ⚠️ bypass RLS ทั้งหมด — ห้ามขึ้นต้นด้วย NEXT_PUBLIC_ และห้าม commit ค่าจริงเด็ดขาด
# ดึงจาก Supabase Dashboard > Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx
